#!/bin/sh
# Waybar module for Toggl Track via toggl-track-track daemon socket
SOCKET="${XDG_RUNTIME_DIR}/toggl-track-track.sock"

# Wait for socket to appear
while [ ! -S "$SOCKET" ]; do
    printf '{"text": "⏸️ --", "tooltip": "Väntar på toggl-track-track...", "class": "stopped"}\n'
    sleep 5
done

# State
entry_json="null"
day="0:00"
week="0:00"
month="0:00"

emit_waybar() {
    if [ "$entry_json" = "null" ]; then
        printf '{"text": "⏸️ %s/%s/%s", "tooltip": "Ingen timer igång\\nIdag: %s | Vecka: %s | Månad: %s", "class": "stopped"}\n' \
            "$day" "$week" "$month" "$day" "$week" "$month"
    else
        desc=$(echo "$entry_json" | jq -r '.description // ""')
        duration=$(echo "$entry_json" | jq -r '.duration.formatted // "00:00:00"')
        project=$(echo "$entry_json" | jq -r '.project.name // empty')

        if [ -n "$desc" ] && [ ${#desc} -gt 20 ]; then
            short_desc="$(echo "$desc" | cut -c1-20)..."
        elif [ -n "$desc" ]; then
            short_desc="$desc"
        else
            short_desc="(no desc)"
        fi

        if [ -n "$project" ]; then
            tooltip="${project}: ${desc}\\nTimer: ${duration}\\nIdag: ${day} | Vecka: ${week} | Månad: ${month}"
        else
            tooltip="${desc}\\nTimer: ${duration}\\nIdag: ${day} | Vecka: ${week} | Månad: ${month}"
        fi

        printf '{"text": "⏱️ %s %s | %s/%s/%s", "tooltip": "%s", "class": "running"}\n' \
            "$short_desc" "$duration" "$day" "$week" "$month" "$tooltip"
    fi
}

# Single socat connection: send initial commands, then listen
{
    printf '{"command":"emit","data":"current_entry"}\n'
    printf '{"command":"emit","data":"stats"}\n'
    # Keep stdin open so socat stays connected
    while true; do sleep 3600; done
} | socat - UNIX-CONNECT:"$SOCKET" | while IFS= read -r line; do
    event=$(echo "$line" | jq -r '.event // empty' 2>/dev/null)
    case "$event" in
        current_entry.changed)
            entry_json=$(echo "$line" | jq -c '.entry')
            emit_waybar
            ;;
        stats.changed)
            day=$(echo "$line" | jq -r '.stats.day.formatted')
            week=$(echo "$line" | jq -r '.stats.week.formatted')
            month=$(echo "$line" | jq -r '.stats.month.formatted')
            emit_waybar
            ;;
    esac
done

#!/usr/bin/python3
"""Fetch SHL + Hockeyallsvenskan matches (past, live, upcoming) from TV4 Play API for eww widget."""

import json
import os
import subprocess
import time as _time
from datetime import datetime, timedelta, timezone

CACHE_FILE = "/tmp/eww-hockey.json"
CACHE_MAX_AGE = 600  # 10 minutes

ICON_DIR = os.path.realpath(os.path.join(os.path.dirname(os.path.abspath(__file__)), "..", "eww", "icons", "teams"))
ICON_MAX_AGE = 86400 * 30  # refresh logos monthly
LOGO_CDN = "https://sportality.cdn.s8y.se/team-logos"

# Map TV4 match title team names → logo file basenames
TEAM_LOGOS = {
    # SHL
    "Brynäs": "bif1_bif", "Brynäs IF": "bif1_bif",
    "Djurgården": "dif1_dif", "Djurgårdens IF": "dif1_dif",
